{
	"name": "css-bash",
	"version": "0.1.0",
	"description": "Modern CSS catalog as a bash sandbox + MCP server. Lets LLMs discover post-2023 CSS features they don't know about.",
	"type": "module",
	"bin": {
		"css-bash": "./bin/css-bash.ts"
	},
	"files": [
		"bin",
		"src/**/*.ts",
		"!src/**/*.test.ts",
		"recipes",
		"README.md",
		"AGENTS.md",
		"LICENSE"
	],
	"scripts": {
		"server": "bun bin/css-bash.ts",
		"repl": "bun bin/css-bash.ts --repl",
		"test": "bun test",
		"lint": "biome check src",
		"format": "biome format --write src"
	},
	"keywords": [
		"css",
		"mcp",
		"modelcontextprotocol",
		"ai",
		"agents",
		"baseline",
		"web-features",
		"bash",
		"just-bash"
	],
	"repository": "github:crafter-station/css-bash",
	"author": "Railly Hugo <railly@crafter-station.com>",
	"license": "MIT",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"just-bash": "^2.14.3",
		"web-features": "^3.25.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "^1.3.13",
		"typescript": "^5.6.0"
	},
	"engines": {
		"bun": ">=1.1.0"
	}
}
